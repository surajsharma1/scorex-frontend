# ScoreX Environment Variables
# Add these to Vercel Dashboard (Settings > Environment Variables)

# Backend API (Render)
VITE_BACKEND_URL=https://scorex-backend.onrender.com
VITE_API_BASE_URL=https://scorex-backend.onrender.com/api/v1

# Local development (uncomment for .env.local)
# VITE_BACKEND_URL=http://localhost:5000
# VITE_API_BASE_URL=http://localhost:5000/api/v1

# Instructions:
# 1. Vercel: Copy these vars to ALL environments (Production/Preview/Development)
# 2. Local: Copy to .env.local for development
# 3. Redeploy after adding vars

