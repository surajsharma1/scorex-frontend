{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
"lib":["ES2020","DOM","DOM.Iterable","DOM","Node"],

    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.*",
    "src/test/**",
    "src/components/AccessibilityTest.tsx",
    "src/components/BracketView.tsx",
    "src/components/LiveTournament.tsx",
    "src/components/MessageChat.tsx",
    "src/i18n.ts"
  ],
  "ts-node": {
    "esm": true
  }
}

